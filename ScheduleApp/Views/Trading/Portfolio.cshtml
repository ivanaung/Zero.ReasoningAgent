@model ScheduleApp.Modules.Trading.TradingPortfolioPageViewModel
@{
    ViewData["Title"] = "Trading Portfolio";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/trading.css" asp-append-version="true" />
}

<div class="d-flex flex-column gap-3">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 d-flex justify-content-between align-items-center gap-3 flex-wrap">
            <div><div class="management-kicker">Trading Advisor</div><h4 class="mb-0 fw-bold">Portfolio</h4>
                @if (!string.IsNullOrWhiteSpace(Model.PriceWarning))
                {
                    <div>@Model.PriceWarning</div>
                }
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-light" asp-action="Index">Dashboard</a>
            </div>
        </div>
    </div>



    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <div class="management-kicker">Portfolio Tracker</div>
            <h6 class="fw-bold mb-3">Add Holding</h6>
            <form asp-action="SaveHolding" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-md-2"><input class="form-control" name="Symbol" placeholder="Symbol" required /></div>
                <div class="col-md-2"><input class="form-control" name="Market" placeholder="Market" required /></div>
                <div class="col-md-3"><input class="form-control" name="CompanyName" placeholder="Company name" required /></div>
                <div class="col-md-1"><input class="form-control" type="number" step="0.0001" name="Quantity" placeholder="Qty" required /></div>
                <div class="col-md-1"><input class="form-control" type="number" step="0.0001" name="AverageCost" placeholder="Avg cost" required /></div>
                <div class="col-md-1"><input class="form-control" name="Currency" placeholder="USD" value="USD" required /></div>
                <div class="col-md-1"><input class="form-control" type="number" step="0.0001" name="CurrentPrice" placeholder="Current" /></div>
                <div class="col-md-8"><input class="form-control" name="Notes" placeholder="Notes" /></div>
                <div class="col-md-2"><button class="btn btn-primary w-100" type="submit">Add Holding</button></div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>Symbol</th><th>Company</th><th>Qty</th><th>Avg Cost</th><th>Current</th><th>Total Cost</th><th>Market Value</th><th>P/L</th><th>Notes</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.Holdings)
                    {
                        var modalId = $"holding-edit-{item.Id}";
                        <tr>
                            <td>@item.Symbol<div class="small text-muted">@item.Market / @item.Currency</div></td>
                            <td>@item.CompanyName</td>
                            <td>@item.Quantity</td>
                            <td>@item.AverageCost.ToString("0.####")</td>
                            <td>@item.CurrentPrice.ToString("0.####")</td>
                            <td>@item.TotalCost.ToString("N2")</td>
                            <td>@item.MarketValue.ToString("N2")</td>
                            <td class="@(item.UnrealizedProfitLoss >= 0 ? "text-success" : "text-danger")">@item.UnrealizedProfitLoss.ToString("N2")<div class="small">@item.UnrealizedProfitLossPercent.ToString("0.##")%</div></td>
                            <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)</td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#@modalId">Edit</button>
                                    <form asp-action="DeleteHolding" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @foreach (var item in Model.Holdings)
    {
        var modalId = $"holding-edit-{item.Id}";
        <div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)-label" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <form asp-action="SaveHolding" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@item.Id" />
                        <div class="modal-header">
                            <div>
                                <div class="management-kicker">Portfolio Tracker</div>
                                <h5 class="modal-title fw-bold" id="@(modalId)-label">Edit @item.Symbol</h5>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">Symbol</label>
                                    <input class="form-control" name="Symbol" value="@item.Symbol" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Market</label>
                                    <input class="form-control" name="Market" value="@item.Market" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Currency</label>
                                    <input class="form-control" name="Currency" value="@item.Currency" required />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Company Name</label>
                                    <input class="form-control" name="CompanyName" value="@item.CompanyName" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Quantity</label>
                                    <input class="form-control" type="number" step="0.0001" name="Quantity" value="@item.Quantity.ToString("0.####")" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Average Cost</label>
                                    <input class="form-control" type="number" step="0.0001" name="AverageCost" value="@item.AverageCost.ToString("0.####")" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Current Price</label>
                                    <input class="form-control" type="number" step="0.0001" name="CurrentPrice" value="@item.CurrentPrice.ToString("0.####")" required />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Notes</label>
                                    <input class="form-control" name="Notes" value="@item.Notes" placeholder="Notes" />
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                            <button class="btn btn-primary" type="submit">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
