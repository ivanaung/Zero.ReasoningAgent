@model ScheduleApp.Models.ViewModels.EventFormViewModel
@{
    ViewData["Title"] = Model.Id > 0 ? $"Edit: {Model.Title}" : "New Task";
}

<div class="row justify-content-center h-100 align-items-start py-4">
    <div class="col-xl-9">
        <partial name="_EventForm" model="Model" />
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
