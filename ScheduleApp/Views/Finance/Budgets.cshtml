@model List<ScheduleApp.Models.FinanceBudget>
@{
    ViewData["Title"] = "Finance Budgets";
}
<div class="card border-0 shadow-sm"><div class="card-body p-3">
    <div class="d-flex justify-content-between align-items-center mb-3"><div><div class="management-kicker">Finance Monitor</div><h4 class="mb-0 fw-bold">Budgets</h4></div><a class="btn btn-light" asp-controller="Finance" asp-action="Index">Back</a></div>
    <form asp-controller="Finance" asp-action="SaveBudget" method="post" class="row g-2 mb-4">
        @Html.AntiForgeryToken()
        <div class="col-md-4"><select class="form-select" name="FinanceCategoryId" asp-items="ViewBag.Categories"></select></div>
        <div class="col-md-2"><select class="form-select" name="Scope">@foreach (var scope in Enum.GetValues<ScheduleApp.Models.FinanceScope>()){<option value="@scope">@scope</option>}</select></div>
        <div class="col-md-2"><input class="form-control" type="number" name="Month" min="1" max="12" value="@DateTime.Today.Month" /></div>
        <div class="col-md-2"><input class="form-control" type="number" name="Year" min="2020" max="2100" value="@DateTime.Today.Year" /></div>
        <div class="col-md-1"><input class="form-control" type="number" step="0.01" name="BudgetAmount" placeholder="Budget" /></div>
        <div class="col-md-1"><button class="btn btn-primary w-100" type="submit">Save</button></div>
    </form>
    <div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th>Category</th><th>Scope</th><th>Month</th><th>Year</th><th class="text-end">Budget</th><th></th></tr></thead><tbody>
    @foreach (var item in Model){<tr><td>@(item.FinanceCategory?.Name ?? "Unknown")</td><td>@item.Scope</td><td>@item.Month</td><td>@item.Year</td><td class="text-end">@item.BudgetAmount.ToString("C")</td><td class="text-end"><form asp-controller="Finance" asp-action="DeleteBudget" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><button class="btn btn-sm btn-outline-danger" type="submit">Delete</button></form></td></tr>}
    </tbody></table></div>
</div></div>
