@model ScheduleApp.Modules.Trading.TradingDashboardViewModel
@{
    ViewData["Title"] = "Trading Dashboard";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/trading.css" asp-append-version="true" />
}

<div class="trading-shell d-flex flex-column gap-3">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <div class="management-kicker">Trading Advisor</div>
                <h4 class="mb-1 fw-bold">Dashboard</h4>
                @if (!string.IsNullOrWhiteSpace(Model.PriceWarning))
                {
                    <div>@Model.PriceWarning</div>
                }               
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <form asp-action="RefreshPrices" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-primary" type="submit">Refresh Prices</button>
                </form>
                <a class="btn btn-light" asp-action="Portfolio">Portfolio</a>
                <a class="btn btn-light" asp-action="Watchlist">Watchlist</a>
                <a class="btn btn-light" asp-action="Journal">Journal</a>
                <a class="btn btn-outline-primary" asp-action="Advisor">Advisor</a>
            </div>
        </div>
    </div>

    
    @if (TempData["TradingRefreshSummary"] is string refreshSummary && !string.IsNullOrWhiteSpace(refreshSummary))
    {
        <div class="alert alert-secondary mb-0">@refreshSummary</div>
    }

    <div class="row g-3">
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="management-kicker">Portfolio</div><h6 class="text-muted">Total Value</h6><div class="fs-4 fw-bold">@Model.TotalMarketValue.ToString("N2")</div></div></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="management-kicker">Portfolio</div><h6 class="text-muted">Total Cost</h6><div class="fs-4 fw-bold">@Model.TotalCost.ToString("N2")</div></div></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="management-kicker">Portfolio</div><h6 class="text-muted">Unrealized P/L</h6><div class="fs-4 fw-bold @(Model.TotalUnrealizedProfitLoss >= 0 ? "text-success" : "text-danger")">@Model.TotalUnrealizedProfitLoss.ToString("N2")</div><div class="small text-muted">@Model.TotalUnrealizedProfitLossPercent.ToString("0.##")%</div></div></div></div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div><div class="management-kicker">Portfolio Tracker</div><h6 class="mb-0 fw-bold">Holdings</h6></div>
                        <a class="btn btn-sm btn-light" asp-action="Portfolio">Manage</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Symbol</th><th>Company</th><th>Qty</th><th>Avg Cost</th><th>Current</th><th class="text-end">Market Value</th><th class="text-end">P/L</th></tr></thead>
                            <tbody>
                            @foreach (var item in Model.Holdings)
                            {
                                <tr>
                                    <td><strong>@item.Symbol</strong><div class="small text-muted">@item.Market / @item.Currency</div></td>
                                    <td>@item.CompanyName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.AverageCost.ToString("0.####")</td>
                                    <td>@item.CurrentPrice.ToString("0.####")</td>
                                    <td class="text-end">@item.MarketValue.ToString("N2")</td>
                                    <td class="text-end @(item.UnrealizedProfitLoss >= 0 ? "text-success" : "text-danger")">@item.UnrealizedProfitLoss.ToString("N2")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div><div class="management-kicker">Advisory</div><h6 class="mb-0 fw-bold">Latest Summary</h6></div>
                        <a class="btn btn-sm btn-light" asp-action="Advisor">Open</a>
                    </div>
                    @if (Model.LatestAdvice is null)
                    {
                        <div class="text-muted small">No advisory snapshot saved yet.</div>
                    }
                    else
                    {
                        <div class="trading-advice-card">
                            <div class="fw-semibold mb-2">@Model.LatestAdvice.Suggestion</div>
                            <div class="small mb-2">@Model.LatestAdvice.PortfolioSummary</div>
                            <div class="small text-muted mb-2">Risk: @Model.LatestAdvice.RiskLevel</div>
                            <div class="small">@Model.LatestAdvice.Reasoning</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div><div class="management-kicker">Watchlist</div><h6 class="mb-0 fw-bold">Alerts</h6></div>
                        <a class="btn btn-sm btn-light" asp-action="Watchlist">Manage</a>
                    </div>
                    @if (Model.Watchlist.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead><tr><th>Symbol</th><th>Status</th><th class="text-end">Price</th></tr></thead>
                                <tbody>
                                @foreach (var item in Model.Watchlist)
                                {
                                    <tr>
                                        <td><strong>@item.Symbol</strong><div class="small text-muted">@item.Market</div></td>
                                        <td>@item.AlertStatus</td>
                                        <td class="text-end">@(item.CurrentPrice?.ToString("0.####") ?? "-")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">No watchlist items yet.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div><div class="management-kicker">Trade Journal</div><h6 class="mb-0 fw-bold">Recent Entries</h6></div>
                        <a class="btn btn-sm btn-light" asp-action="Journal">Manage</a>
                    </div>
                    @if (Model.RecentJournalEntries.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead><tr><th>Date</th><th>Symbol</th><th>Action</th><th>Reason</th></tr></thead>
                                <tbody>
                                @foreach (var item in Model.RecentJournalEntries)
                                {
                                    <tr>
                                        <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                                        <td>@item.Symbol</td>
                                        <td>@item.ActionType</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Reason) ? "-" : item.Reason)</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">No journal entries yet.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
