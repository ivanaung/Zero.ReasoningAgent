@model ScheduleApp.Modules.Trading.TradingJournalPageViewModel
@{
    ViewData["Title"] = "Trading Journal";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/trading.css" asp-append-version="true" />
}

<div class="d-flex flex-column gap-3">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 d-flex justify-content-between align-items-center">
            <div><div class="management-kicker">Trading Advisor</div><h4 class="mb-0 fw-bold">Journal</h4></div>
            <a class="btn btn-light" asp-action="Index">Dashboard</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <div class="management-kicker">Trade Journal</div>
            <h6 class="fw-bold mb-3">Add Entry</h6>
            <form asp-action="AddJournalEntry" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-md-2"><input class="form-control" name="Symbol" placeholder="Symbol" required /></div>
                <div class="col-md-2">
                    <select class="form-select" name="ActionType">
                        @foreach (var action in Enum.GetValues<ScheduleApp.Modules.Trading.TradingJournalActionType>())
                        {
                            <option value="@action">@action</option>
                        }
                    </select>
                </div>
                <div class="col-md-2"><input class="form-control" type="number" step="0.0001" name="Price" placeholder="Price" /></div>
                <div class="col-md-2"><input class="form-control" type="number" step="0.0001" name="Quantity" placeholder="Quantity" /></div>
                <div class="col-md-4"><input class="form-control" name="Reason" placeholder="Reason" /></div>
                <div class="col-md-3"><input class="form-control" name="Emotion" placeholder="Emotion" /></div>
                <div class="col-md-7"><input class="form-control" name="LessonLearned" placeholder="Lesson learned" /></div>
                <div class="col-md-2"><button class="btn btn-primary w-100" type="submit">Add Entry</button></div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>Date</th><th>Symbol</th><th>Action</th><th>Price</th><th>Qty</th><th>Reason</th><th>Emotion</th><th>Lesson</th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.Entries)
                    {
                        <tr>
                            <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@item.Symbol</td>
                            <td>@item.ActionType</td>
                            <td>@(item.Price?.ToString("0.####") ?? "-")</td>
                            <td>@(item.Quantity?.ToString("0.####") ?? "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Reason) ? "-" : item.Reason)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Emotion) ? "-" : item.Emotion)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.LessonLearned) ? "-" : item.LessonLearned)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
