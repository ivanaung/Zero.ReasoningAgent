@model ScheduleApp.Modules.Trading.TradingWatchlistPageViewModel
@{
    ViewData["Title"] = "Trading Watchlist";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/trading.css" asp-append-version="true" />
}

<div class="d-flex flex-column gap-3">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 d-flex justify-content-between align-items-center">
            <div><div class="management-kicker">Trading Advisor</div><h4 class="mb-0 fw-bold">Watchlist</h4></div>
            <a class="btn btn-light" asp-action="Index">Dashboard</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.PriceWarning))
    {
        <div class="alert alert-secondary mb-0">@Model.PriceWarning</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <div class="management-kicker">Watchlist</div>
            <h6 class="fw-bold mb-3">Add Watchlist Item</h6>
            <form asp-action="SaveWatchlistItem" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-md-2"><input class="form-control" name="Symbol" placeholder="Symbol" required /></div>
                <div class="col-md-2"><input class="form-control" name="Market" placeholder="Market" required /></div>
                <div class="col-md-2"><input class="form-control" type="number" step="0.0001" name="TargetBuyPrice" placeholder="Target buy" /></div>
                <div class="col-md-2"><input class="form-control" type="number" step="0.0001" name="TargetSellPrice" placeholder="Target sell" /></div>
                <div class="col-md-2"><input class="form-control" type="number" step="0.0001" name="AlertBelowPrice" placeholder="Alert below" /></div>
                <div class="col-md-2"><input class="form-control" type="number" step="0.0001" name="AlertAbovePrice" placeholder="Alert above" /></div>
                <div class="col-md-8"><input class="form-control" name="Notes" placeholder="Notes" /></div>
                <div class="col-md-2 form-check d-flex align-items-center ps-4"><input class="form-check-input me-2" type="checkbox" name="IsActive" checked value="true" /><label class="form-check-label">Active</label></div>
                <div class="col-md-2"><button class="btn btn-primary w-100" type="submit">Add Item</button></div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>Symbol</th><th>Status</th><th>Current</th><th>Target Buy</th><th>Target Sell</th><th>Alerts</th><th>Notes</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Symbol<div class="small text-muted">@item.Market</div></td>
                            <td>@item.AlertStatus</td>
                            <td>@(item.CurrentPrice?.ToString("0.####") ?? "-")</td>
                            <td>@(item.TargetBuyPrice?.ToString("0.####") ?? "-")</td>
                            <td>@(item.TargetSellPrice?.ToString("0.####") ?? "-")</td>
                            <td>Below: @(item.AlertBelowPrice?.ToString("0.####") ?? "-")<br />Above: @(item.AlertAbovePrice?.ToString("0.####") ?? "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)</td>
                            <td class="text-end">
                                <form asp-action="DeleteWatchlistItem" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
