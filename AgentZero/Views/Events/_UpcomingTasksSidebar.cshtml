@using ScheduleApp.Models.ViewModels
@model IReadOnlyList<AgendaItemViewModel>

<div class="card border-0 shadow-sm mt-3 flex-grow-1 d-flex flex-column calendar-upcoming-card">
    <div class="card-body p-3 d-flex flex-column h-100">
        <div class="d-flex align-items-center mb-3">
            <i class="bi bi-calendar-event me-2 text-primary"></i>
            <h6 class="mb-0 fw-bold">Upcoming Tasks</h6>
        </div>

        <div class="dashboard-list flex-grow-1 overflow-auto pe-1">
            @if (Model.Any())
            {
                @foreach (var task in Model)
                {
                    <button class="dashboard-task-row d-flex align-items-start gap-2 p-2 w-100 border-0 bg-transparent text-start rounded text-decoration-none text-dark"
                            style="transition: background-color 0.15s ease;"
                            onmouseover="this.style.backgroundColor='#f8f9fa'"
                            onmouseout="this.style.backgroundColor='transparent'"
                            data-event-modal-url="@Url.Action("Edit", "Events", new { id = task.Id })"
                            data-event-modal-title="Edit Task"
                            onclick="window.openEventModal(this.dataset.eventModalUrl, this.dataset.eventModalTitle)">
                        <span class="dashboard-task-dot mt-1 flex-shrink-0" style="background-color: @task.Color"></span>
                        <div class="flex-grow-1 min-w-0" style="line-height: 1.2;">
                            <div class="fw-bold text-truncate" style="font-size: 0.85rem;">@(string.IsNullOrWhiteSpace(task.Icon) ? task.Title : $"{task.Icon} {task.Title}")</div>
                            <div class="text-muted" style="font-size: 0.75rem;">@task.TimeLabel</div>
                        </div>
                    </button>
                }
            }
            else
            {
                <div class="text-muted small italic">No open tasks are scheduled next.</div>
            }
        </div>
    </div>
</div>
