<template id="finance-summary-template">
    <div class="dashboard-widget-card card border-0 shadow-sm h-100">
        <div class="card-body d-flex flex-column p-3">
            <div class="dashboard-widget-header">
                <div>
                    <div class="management-kicker">Finance Monitor</div>
                    <h6 class="mb-0 fw-bold">Finance Summary</h6>
                </div>
                <div class="dashboard-widget-actions">
                    <div class="btn btn-white icon-btn grid-handle" aria-label="Drag widget" style="cursor: grab; display: inline-flex; align-items: center; justify-content: center;">
                        <i class="bi bi-arrows-move"></i>
                    </div>
                    <button class="btn btn-white icon-btn widget-remove" type="button" aria-label="Remove widget">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
            <div class="row g-2 flex-grow-1">
                <div class="col-6">
                    <div class="dashboard-stat-card">
                        <span>Income</span>
                        <strong>@(Model.FinanceSummary?.MonthlyIncome.ToString("C") ?? "$0.00")</strong>
                    </div>
                </div>
                <div class="col-6">
                    <div class="dashboard-stat-card">
                        <span>Expense</span>
                        <strong>@(Model.FinanceSummary?.MonthlyExpense.ToString("C") ?? "$0.00")</strong>
                    </div>
                </div>
                <div class="col-6">
                    <div class="dashboard-stat-card">
                        <span>Net</span>
                        <strong>@(Model.FinanceSummary?.Net.ToString("C") ?? "$0.00")</strong>
                    </div>
                </div>
                <div class="col-6">
                    <div class="dashboard-stat-card dashboard-stat-alert">
                        <span>Warnings</span>
                        <strong>@(Model.FinanceSummary?.BudgetWarningCount ?? 0)</strong>
                    </div>
                </div>
            </div>
            <div class="small text-muted mt-3">
                Next bill:
                <strong>@(Model.FinanceSummary?.NextUpcomingBill?.Name ?? "None")</strong>
                @if (Model.FinanceSummary?.NextUpcomingBill != null)
                {
                    <span> - @Model.FinanceSummary.NextUpcomingBill.NextDueDate.ToString("yyyy-MM-dd")</span>
                }
            </div>
        </div>
    </div>
</template>

@section Scripts {
    <script src="~/lib/gridstack/gridstack-all.js" asp-append-version="true"></script>
    <script src="~/lib/chartjs/chart.umd.min.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const storageKey = 'progress-dashboard-layout-v3';
            const editModeKey = 'progress-dashboard-edit-mode';
            const projectProgress = @Html.Raw(projectProgressJson);
            const stageProgress = @Html.Raw(stageProgressJson);
            const statusBreakdown = @Html.Raw(statusBreakdownJson);
            const priorityBreakdown = @Html.Raw(priorityBreakdownJson);
            const charts = new Map();
            const dashboardShell = document.querySelector('.dashboard-shell');
            const dashboardEditPanel = document.getElementById('dashboardEditPanel');
            const dashboardEditToggle = document.getElementById('dashboardEditToggle');

            GridStack.renderCB = function (el, widget) {
                el.innerHTML = widget.content || '';
            };

            const defaultLayout = [
                { id: 'project-progress', x: 0, y: 0, w: 6, h: 4 },
                { id: 'status-breakdown', x: 6, y: 0, w: 4, h: 4 },
                { id: 'priority-focus', x: 0, y: 4, w: 4, h: 4 },
                { id: 'quick-stats', x: 4, y: 4, w: 4, h: 3 },
                { id: 'finance-summary', x: 8, y: 4, w: 4, h: 3 }
            ];

            const grid = GridStack.init({
                margin: 8,
                float: true,
                cellHeight: 80,
                minRow: 1,
                handle: '.grid-handle'
            }, '.dashboard-grid');

            let isEditMode = localStorage.getItem(editModeKey) === 'true';

            function applyEditMode() {
                dashboardShell?.classList.toggle('dashboard-editing', isEditMode);
                dashboardEditPanel.hidden = !isEditMode;
                dashboardEditToggle.classList.toggle('active', isEditMode);
                dashboardEditToggle.setAttribute('aria-pressed', isEditMode ? 'true' : 'false');
                grid.setStatic(!isEditMode);
            }

            function updateWidgetPickerState() {
                const activeIds = new Set(getCurrentIds());
                document.querySelectorAll('[data-add-widget]').forEach(button => {
                    const isActive = activeIds.has(button.dataset.addWidget);
                    button.classList.toggle('active', isActive);
                    button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                });
            }

            function getWidgetLayout() {
                const saved = localStorage.getItem(storageKey);
                if (!saved) return defaultLayout;
                try {
                    return JSON.parse(saved);
                } catch {
                    return defaultLayout;
                }
            }

            function saveLayout() {
                const layout = grid.save(false).map(node => ({
                    id: node.id,
                    x: node.x,
                    y: node.y,
                    w: node.w,
                    h: node.h
                }));
                localStorage.setItem(storageKey, JSON.stringify(layout));
                updateWidgetPickerState();
            }

            function createChart(canvas, type) {
                if (!canvas || charts.has(canvas)) return;
                const ctx = canvas.getContext('2d');

                if (type === 'project-progress') {
                    charts.set(canvas, new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: projectProgress.map(item => item.name),
                            datasets: [{
                                label: 'Completion %',
                                data: projectProgress.map(item => item.progress),
                                backgroundColor: projectProgress.map(item => item.color + 'CC'),
                                borderColor: projectProgress.map(item => item.color),
                                borderWidth: 1,
                                borderRadius: 10,
                                maxBarThickness: 34
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                x: { grid: { display: false } },
                                y: { beginAtZero: true, max: 100 }
                            }
                        }
                    }));
                    return;
                }

                if (type === 'status-breakdown') {
                    charts.set(canvas, new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: statusBreakdown.map(item => item.label),
                            datasets: [{
                                data: statusBreakdown.map(item => item.count),
                                backgroundColor: ['#94A3B8', '#3B82F6', '#10B981', '#6B7280', '#EF4444'],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            cutout: '68%',
                            plugins: {
                                legend: { position: 'bottom' }
                            }
                        }
                    }));
                    return;
                }

                if (type === 'stage-progress') {
                    charts.set(canvas, new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: stageProgress.map(item => item.name),
                            datasets: [{
                                label: 'Stage Progress %',
                                data: stageProgress.map(item => item.progress),
                                backgroundColor: stageProgress.map(item => item.color + 'CC'),
                                borderColor: stageProgress.map(item => item.color),
                                borderWidth: 1,
                                borderRadius: 10,
                                maxBarThickness: 28
                            }]
                        },
                        options: {
                            indexAxis: 'y',
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                x: { beginAtZero: true, max: 100, grid: { color: 'rgba(148, 163, 184, 0.18)' } },
                                y: { grid: { display: false } }
                            }
                        }
                    }));
                    return;
                }

                if (type === 'priority-focus') {
                    charts.set(canvas, new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: priorityBreakdown.map(item => item.label),
                            datasets: [{
                                label: 'Open Tasks',
                                data: priorityBreakdown.map(item => item.count),
                                backgroundColor: ['#CBD5E1', '#60A5FA', '#F59E0B', '#DC2626'],
                                borderRadius: 10,
                                borderWidth: 0,
                                maxBarThickness: 34
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                x: { grid: { display: false } },
                                y: { beginAtZero: true }
                            }
                        }
                    }));
                }
            }

            function mountWidget(node) {
                const template = document.getElementById(`${node.id}-template`);
                if (!template) return;

                const content = template.content.firstElementChild.cloneNode(true);
                const widget = grid.addWidget({
                    id: node.id,
                    x: node.x,
                    y: node.y,
                    w: node.w,
                    h: node.h,
                    content: content.outerHTML
                });

                const removeButton = widget.querySelector('.widget-remove');
                if (removeButton) {
                    removeButton.addEventListener('click', function () {
                        if (!isEditMode) {
                            return;
                        }

                        const canvas = widget.querySelector('canvas');
                        if (canvas && charts.has(canvas)) {
                            charts.get(canvas).destroy();
                            charts.delete(canvas);
                        }
                        grid.removeWidget(widget);
                        saveLayout();
                    });
                }

                const canvas = widget.querySelector('canvas[data-chart-type]');
                if (canvas) {
                    createChart(canvas, canvas.dataset.chartType);
                }
            }

            function renderLayout(layout) {
                grid.removeAll(true, false);
                charts.forEach(chart => chart.destroy());
                charts.clear();

                layout.forEach(mountWidget);
                saveLayout();
            }

            function getCurrentIds() {
                return grid.save(false).map(node => node.id);
            }

            dashboardEditToggle?.addEventListener('click', function () {
                isEditMode = !isEditMode;
                localStorage.setItem(editModeKey, isEditMode ? 'true' : 'false');
                applyEditMode();
            });

            document.querySelectorAll('[data-add-widget]').forEach(button => {
                button.addEventListener('click', function () {
                    if (!isEditMode) {
                        return;
                    }

                    const id = this.dataset.addWidget;
                    if (getCurrentIds().includes(id)) {
                        return;
                    }

                    const node = defaultLayout.find(item => item.id === id) || { id, x: 0, y: 99, w: 4, h: 4 };
                    mountWidget(node);
                    saveLayout();
                });
            });

            document.getElementById('resetDashboardLayout')?.addEventListener('click', function () {
                localStorage.removeItem(storageKey);
                renderLayout(defaultLayout);
            });

            grid.on('change removed added', function () {
                saveLayout();
            });

            renderLayout(getWidgetLayout());
            applyEditMode();
            updateWidgetPickerState();

            window.refreshCalendarEvents = null;

            document.addEventListener('change', async function(e) {
                if (e.target && e.target.classList.contains('todo-checkbox')) {
                    const taskId = e.target.dataset.taskId;
                    const isChecked = e.target.checked;
                    const row = e.target.closest('.todo-task-row');
                    const titles = row.querySelectorAll('.todo-title, small');
                    
                    if (isChecked) {
                        row.classList.add('todo-task-done');
                        titles.forEach(el => el.classList.add('text-decoration-line-through', 'text-muted'));
                    } else {
                        row.classList.remove('todo-task-done');
                        titles.forEach(el => el.classList.remove('text-decoration-line-through', 'text-muted'));
                    }

                    try {
                        const newStatus = isChecked ? 'Done' : 'Todo';
                        const updateStatusUrl = '@Html.Raw(Url.Action("UpdateStatus", "Events"))';
                        await fetch(`${updateStatusUrl}?id=${encodeURIComponent(taskId)}&status=${encodeURIComponent(newStatus)}`, { method: 'POST' });
                    } catch (error) {
                        console.error('Failed to update task status:', error);
                        // Revert on error
                        e.target.checked = !isChecked;
                    }
                }
            });
        });
    </script>
}
