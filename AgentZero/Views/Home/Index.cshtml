        <div class="card-body d-flex flex-column p-3">
            <div class="dashboard-widget-header">
                <div>
                    <div class="management-kicker">Summary Widget</div>
                    <h6 class="mb-0 fw-bold">Quick Stats</h6>
                </div>
                <div class="dashboard-widget-actions">
                    <div class="btn btn-white icon-btn grid-handle" aria-label="Drag widget" style="cursor: grab; display: inline-flex; align-items: center; justify-content: center;">
                        <i class="bi bi-arrows-move"></i>
                    </div>
                    <button class="btn btn-white icon-btn widget-remove" type="button" aria-label="Remove widget">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
            <div class="row g-2 flex-grow-1">
                <div class="col-6">
                    <div class="dashboard-stat-card">
                        <span>Active Projects</span>
                        <strong>@Model.ActiveProjects</strong>
                    </div>
                </div>
                <div class="col-6">
                    <div class="dashboard-stat-card">
                        <span>Open Tasks</span>
                        <strong>@Model.OpenTasks</strong>
                    </div>
                </div>
                <div class="col-6">
                    <div class="dashboard-stat-card">
                        <span>Done Today</span>
                        <strong>@Model.CompletedToday</strong>
                    </div>
                </div>
                <div class="col-6">
                    <div class="dashboard-stat-card dashboard-stat-alert">
                        <span>Overdue</span>
                        <strong>@Model.OverdueTasks</strong>
                    </div>
                </div>
            </div>
