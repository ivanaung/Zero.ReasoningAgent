@model List<ScheduleApp.Models.FinanceRecurringItem>
@{
    ViewData["Title"] = "Finance Recurring";
}
<div class="card border-0 shadow-sm"><div class="card-body p-3">
    <div class="d-flex justify-content-between align-items-center mb-3"><div><div class="management-kicker">Finance Monitor</div><h4 class="mb-0 fw-bold">Recurring Items</h4></div><a class="btn btn-light" asp-controller="Finance" asp-action="Index">Back</a></div>
    <form asp-controller="Finance" asp-action="SaveRecurring" method="post" class="row g-2 mb-4">
        @Html.AntiForgeryToken()
        <div class="col-md-3"><input class="form-control" name="Name" placeholder="Name" /></div>
        <div class="col-md-2"><select class="form-select" name="FinanceAccountId" asp-items="ViewBag.Accounts"><option value="">Account</option></select></div>
        <div class="col-md-2"><select class="form-select" name="FinanceCategoryId" asp-items="ViewBag.Categories"><option value="">Category</option></select></div>
        <div class="col-md-2"><select class="form-select" name="ProjectId" asp-items="ViewBag.Projects"><option value="">Project</option></select></div>
        <div class="col-md-1"><select class="form-select" name="Type">@foreach (var type in Enum.GetValues<ScheduleApp.Models.FinanceCategoryType>()){<option value="@type">@type</option>}</select></div>
        <div class="col-md-1"><select class="form-select" name="Scope">@foreach (var scope in Enum.GetValues<ScheduleApp.Models.FinanceScope>()){<option value="@scope">@scope</option>}</select></div>
        <div class="col-md-1"><input class="form-control" type="number" step="0.01" name="Amount" placeholder="Amt" /></div>
        <div class="col-md-2"><select class="form-select" name="Frequency">@foreach (var type in Enum.GetValues<ScheduleApp.Models.FinanceRecurringFrequency>()){<option value="@type">@type</option>}</select></div>
        <div class="col-md-2"><input class="form-control" type="date" name="NextDueDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
        <div class="col-md-1"><select class="form-select" name="IsActive"><option value="true">Active</option><option value="false">Inactive</option></select></div>
        <div class="col-md-1"><button class="btn btn-primary w-100" type="submit">Save</button></div>
    </form>
    <div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th>Name</th><th>Due</th><th>Scope</th><th>Frequency</th><th>Project</th><th class="text-end">Amount</th><th></th></tr></thead><tbody>
    @foreach (var item in Model){<tr><td>@item.Name<div class="small text-muted">@(item.FinanceCategory?.Name ?? "No category")</div></td><td>@item.NextDueDate.ToString("yyyy-MM-dd")</td><td>@item.Scope</td><td>@item.Frequency</td><td>@(item.Project?.Name ?? "-")</td><td class="text-end">@item.Amount.ToString("C")</td><td class="text-end"><form asp-controller="Finance" asp-action="DeleteRecurring" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><button class="btn btn-sm btn-outline-danger" type="submit">Delete</button></form></td></tr>}
    </tbody></table></div>
</div></div>
