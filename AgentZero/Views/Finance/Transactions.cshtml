@model List<ScheduleApp.Models.ViewModels.FinanceTransactionListItemViewModel>
@{
    ViewData["Title"] = "Finance Transactions";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div><div class="management-kicker">Finance Monitor</div><h4 class="mb-0 fw-bold">Transactions</h4></div>
            <a class="btn btn-light" asp-controller="Finance" asp-action="Index">Back</a>
        </div>
        <form asp-controller="Finance" asp-action="SaveTransaction" method="post" class="row g-2 mb-4">
            @Html.AntiForgeryToken()
            <div class="col-md-2"><input class="form-control" type="date" name="TransactionDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
            <div class="col-md-2"><select class="form-select" name="FinanceAccountId" asp-items="ViewBag.Accounts"></select></div>
            <div class="col-md-2"><select class="form-select" name="FinanceCategoryId" asp-items="ViewBag.Categories"></select></div>
            <div class="col-md-2"><select class="form-select" name="ProjectId" asp-items="ViewBag.Projects"><option value="">Project (Optional)</option></select></div>
            <div class="col-md-1"><select class="form-select" name="Scope">@foreach (var scope in Enum.GetValues<ScheduleApp.Models.FinanceScope>()){<option value="@scope">@scope</option>}</select></div>
            <div class="col-md-1"><select class="form-select" name="Type">@foreach (var type in Enum.GetValues<ScheduleApp.Models.FinanceTransactionType>()){<option value="@type">@type</option>}</select></div>
            <div class="col-md-2"><input class="form-control" type="number" step="0.01" name="Amount" placeholder="Amount" /></div>
            <div class="col-md-3"><input class="form-control" name="Description" placeholder="Description" /></div>
            <div class="col-md-2"><input class="form-control" name="PaymentMethod" placeholder="Payment method" /></div>
            <div class="col-md-5"><input class="form-control" name="Notes" placeholder="Notes" /></div>
            <div class="col-md-2"><button class="btn btn-primary w-100" type="submit">Add Transaction</button></div>
        </form>

        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead><tr><th>Date</th><th>Description</th><th>Account</th><th>Category</th><th>Project</th><th>Scope</th><th>Type</th><th class="text-end">Amount</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TransactionDate.ToString("yyyy-MM-dd")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>
                        <td>@item.AccountName</td>
                        <td>@item.CategoryName</td>
                        <td>@(item.ProjectName ?? "-")</td>
                        <td>@item.Scope</td>
                        <td>@item.Type</td>
                        <td class="text-end">@item.Amount.ToString("C")</td>
                        <td class="text-end">
                            <form asp-controller="Finance" asp-action="DeleteTransaction" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
