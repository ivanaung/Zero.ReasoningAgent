@model List<ScheduleApp.Models.FinanceAccount>
@{
    ViewData["Title"] = "Finance Accounts";
}
<div class="card border-0 shadow-sm"><div class="card-body p-3">
    <div class="d-flex justify-content-between align-items-center mb-3"><div><div class="management-kicker">Finance Monitor</div><h4 class="mb-0 fw-bold">Accounts</h4></div><a class="btn btn-light" asp-controller="Finance" asp-action="Index">Back</a></div>
    <form asp-controller="Finance" asp-action="SaveAccount" method="post" class="row g-2 mb-4">
        @Html.AntiForgeryToken()
        <div class="col-md-4"><input class="form-control" name="Name" placeholder="Account name" /></div>
        <div class="col-md-2"><select class="form-select" name="Type">@foreach (var type in Enum.GetValues<ScheduleApp.Models.FinanceAccountType>()){<option value="@type">@type</option>}</select></div>
        <div class="col-md-2"><select class="form-select" name="Scope">@foreach (var scope in Enum.GetValues<ScheduleApp.Models.FinanceScope>()){<option value="@scope">@scope</option>}</select></div>
        <div class="col-md-2"><input class="form-control" type="number" step="0.01" name="OpeningBalance" placeholder="Opening balance" /></div>
        <div class="col-md-1"><select class="form-select" name="IsActive"><option value="true">Active</option><option value="false">Inactive</option></select></div>
        <div class="col-md-1"><button class="btn btn-primary w-100" type="submit">Save</button></div>
    </form>
    <div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th>Name</th><th>Type</th><th>Scope</th><th class="text-end">Opening</th><th>Status</th><th></th></tr></thead><tbody>
    @foreach (var item in Model){<tr><td>@item.Name</td><td>@item.Type</td><td>@item.Scope</td><td class="text-end">@item.OpeningBalance.ToString("C")</td><td>@(item.IsActive ? "Active" : "Inactive")</td><td class="text-end"><form asp-controller="Finance" asp-action="DeleteAccount" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><button class="btn btn-sm btn-outline-danger" type="submit">Delete</button></form></td></tr>}
    </tbody></table></div>
</div></div>
