@model ScheduleApp.Models.ViewModels.FinanceDashboardViewModel
@{
    ViewData["Title"] = "Finance";
}

<div class="d-flex flex-column gap-3">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <div class="management-kicker">Finance Monitor</div>
                <h4 class="mb-1 fw-bold">Finance Dashboard</h4>
                <div class="text-muted small">Personal and business finance overview for @Model.MonthStart.ToString("MMMM yyyy")</div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-light" asp-controller="Finance" asp-action="Transactions">Transactions</a>
                <a class="btn btn-light" asp-controller="Finance" asp-action="Accounts">Accounts</a>
                <a class="btn btn-light" asp-controller="Finance" asp-action="Categories">Categories</a>
                <a class="btn btn-light" asp-controller="Finance" asp-action="Budgets">Budgets</a>
                <a class="btn btn-light" asp-controller="Finance" asp-action="Recurring">Recurring</a>
                <a class="btn btn-primary" asp-controller="Finance" asp-action="Export" asp-route-month="@Model.MonthStart.Month" asp-route-year="@Model.MonthStart.Year">Export</a>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="management-kicker">This Month</div><h6 class="text-muted">Income</h6><div class="fs-4 fw-bold text-success">@Model.MonthlyIncome.ToString("C")</div></div></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="management-kicker">This Month</div><h6 class="text-muted">Expense</h6><div class="fs-4 fw-bold text-danger">@Model.MonthlyExpense.ToString("C")</div></div></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="management-kicker">This Month</div><h6 class="text-muted">Net Balance</h6><div class="fs-4 fw-bold @(Model.Net >= 0 ? "text-primary" : "text-danger")">@Model.Net.ToString("C")</div></div></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="management-kicker">Scope</div><h6 class="text-muted">Personal Spending</h6><div class="fs-5 fw-bold">@Model.PersonalSpending.ToString("C")</div></div></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="management-kicker">Scope</div><h6 class="text-muted">Business Spending</h6><div class="fs-5 fw-bold">@Model.BusinessSpending.ToString("C")</div></div></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="management-kicker">Warnings</div><h6 class="text-muted">Budget Warnings</h6><div class="fs-5 fw-bold">@Model.BudgetWarningCount</div></div></div></div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div><div class="management-kicker">Reminder Surface</div><h6 class="mb-0 fw-bold">Upcoming Bills</h6></div>
                        <a class="btn btn-sm btn-light" asp-controller="Finance" asp-action="Recurring">Manage</a>
                    </div>
                    @if (Model.UpcomingBills.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead><tr><th>Name</th><th>Due</th><th>Scope</th><th class="text-end">Amount</th></tr></thead>
                                <tbody>
                                @foreach (var item in Model.UpcomingBills)
                                {
                                    <tr>
                                        <td><strong>@item.Name</strong><div class="small text-muted">@(item.CategoryName ?? "No category")</div></td>
                                        <td>@item.NextDueDate.ToString("yyyy-MM-dd")</td>
                                        <td>@item.Scope</td>
                                        <td class="text-end">@item.Amount.ToString("C")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">No upcoming bills.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div><div class="management-kicker">Budget Control</div><h6 class="mb-0 fw-bold">Budget Warnings</h6></div>
                        <a class="btn btn-sm btn-light" asp-controller="Finance" asp-action="Budgets">Manage</a>
                    </div>
                    @if (Model.BudgetWarnings.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead><tr><th>Category</th><th>Scope</th><th class="text-end">Budget</th><th class="text-end">Actual</th></tr></thead>
                                <tbody>
                                @foreach (var item in Model.BudgetWarnings)
                                {
                                    <tr>
                                        <td>@item.CategoryName</td>
                                        <td>@item.Scope</td>
                                        <td class="text-end">@item.BudgetAmount.ToString("C")</td>
                                        <td class="text-end text-danger fw-semibold">@item.ActualAmount.ToString("C")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">No budget warnings this month.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="management-kicker">Transactions</div>
                    <h6 class="mb-3 fw-bold">Recent Transactions</h6>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Date</th><th>Description</th><th>Scope</th><th class="text-end">Amount</th></tr></thead>
                            <tbody>
                            @foreach (var item in Model.RecentTransactions)
                            {
                                <tr>
                                    <td>@item.TransactionDate.ToString("yyyy-MM-dd")</td>
                                    <td><strong>@(string.IsNullOrWhiteSpace(item.Description) ? item.CategoryName : item.Description)</strong><div class="small text-muted">@item.AccountName / @item.CategoryName</div></td>
                                    <td>@item.Scope</td>
                                    <td class="text-end @(item.Type == ScheduleApp.Models.FinanceTransactionType.Income ? "text-success" : "text-danger")">@item.Amount.ToString("C")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="management-kicker">Project Link</div>
                    <h6 class="mb-3 fw-bold">Project-linked Transactions</h6>
                    @if (Model.ProjectLinkedTransactions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead><tr><th>Project</th><th>Description</th><th>Date</th><th class="text-end">Amount</th></tr></thead>
                                <tbody>
                                @foreach (var item in Model.ProjectLinkedTransactions)
                                {
                                    <tr>
                                        <td>@(item.ProjectName ?? "Unlinked")</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Description) ? item.CategoryName : item.Description)</td>
                                        <td>@item.TransactionDate.ToString("yyyy-MM-dd")</td>
                                        <td class="text-end">@item.Amount.ToString("C")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">No project-linked finance transactions yet.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
