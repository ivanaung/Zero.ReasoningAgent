                                                @if (Model.DatabaseTestResult.Success)
                                                {
                                                    <div class="small text-muted mt-1">Database: <strong>@Model.DatabaseTestResult.Database</strong> - User: <strong>@Model.DatabaseTestResult.User</strong></div>
                                                    <div class="small text-muted">@Model.DatabaseTestResult.ServerVersion</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }

                                @if (TempData["DatabaseOperationalSync"] is string databaseOperationalSync)
                                {
                                    <div class="settings-card-block">
                                        <div class="d-flex align-items-start gap-2">
                                            <i class="bi bi-database-check text-success mt-1"></i>
                                            <div class="fw-bold small">@databaseOperationalSync</div>
                                        </div>
                                    </div>
                                }

                                @if (TempData["DatabaseOperationalSyncError"] is string databaseOperationalSyncError)
                                {
                                    <div class="settings-card-block">
                                        <div class="d-flex align-items-start gap-2">
                                            <i class="bi bi-database-exclamation text-danger mt-1"></i>
                                            <div class="fw-bold small">@databaseOperationalSyncError</div>
                                        </div>
                                    </div>
                                }

                                <div class="settings-card-block">
                                    <div class="row g-3 align-items-end">
                                        <div class="col-md-4">
                                            <div class="form-check form-switch">
                                                <input asp-for="Database.IsEnabled" class="form-check-input" type="checkbox" />
                                                <label asp-for="Database.IsEnabled" class="form-check-label fw-bold small">Enable PostgreSQL target</label>
                                            </div>
                                            <div class="form-text">Events use PostgreSQL when it is reachable; otherwise Progress falls back to SQLite.</div>
                                        </div>
                                        <div class="col-md-5">
                                            <label asp-for="Database.Host" class="form-label fw-bold small">Host</label>
                                            <input asp-for="Database.Host" class="form-control" placeholder="localhost" />
                                            <span asp-validation-for="Database.Host" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-3">
                                            <label asp-for="Database.Port" class="form-label fw-bold small">Port</label>
                                            <input asp-for="Database.Port" class="form-control" type="number" min="1" max="65535" />
                                            <span asp-validation-for="Database.Port" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label asp-for="Database.DatabaseName" class="form-label fw-bold small">Database</label>
                                            <input asp-for="Database.DatabaseName" class="form-control" />
                                            <span asp-validation-for="Database.DatabaseName" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label asp-for="Database.Username" class="form-label fw-bold small">Username</label>
                                            <input asp-for="Database.Username" class="form-control" autocomplete="username" />
                                            <span asp-validation-for="Database.Username" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label asp-for="Database.Password" class="form-label fw-bold small">Password</label>
                                            <input asp-for="Database.Password" class="form-control" type="password" autocomplete="new-password" placeholder="Leave blank to keep existing" />
                                            <div class="form-text">Current: @(Model.Database.HasPassword ? "configured" : "not configured")</div>
                                            <span asp-validation-for="Database.Password" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label asp-for="Database.SslMode" class="form-label fw-bold small">SSL Mode</label>
                                            <select asp-for="Database.SslMode" class="form-select">
                                                @foreach (var mode in new[] { "Disable", "Allow", "Prefer", "Require", "VerifyCA", "VerifyFull" })
                                                {
                                                    <option value="@mode">@mode</option>
                                                }
                                            </select>
                                            <span asp-validation-for="Database.SslMode" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-check form-switch pt-md-4">
                                                <input asp-for="Database.ClearPassword" class="form-check-input" type="checkbox" />
                                                <label asp-for="Database.ClearPassword" class="form-check-label fw-bold small">Clear saved password</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4 text-md-end">
                                            <div class="small text-muted pt-md-4">Last saved: <strong>@(Model.Database.UpdatedAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "Not saved")</strong></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="settings-form-actions gap-2 flex-wrap">
                                    <button type="submit" class="btn btn-outline-primary px-4" formaction="@Url.Action("TestDatabase", "Settings")">
                                        <i class="bi bi-plug"></i> Test Connection
                                    </button>
                                    <button type="submit" class="btn btn-primary px-4" formaction="@Url.Action("SaveDatabase", "Settings")">
                                        <i class="bi bi-save"></i> Save Database
                                    </button>
                                </div>
                            </form>
                        </div>

                        <div class="tab-pane fade settings-tab-pane @(isMarketDataTab ? "show active" : string.Empty)" id="settings-market-data" role="tabpanel" aria-labelledby="settings-market-data-tab" tabindex="0">
                            <form method="post" id="marketDataSettingsForm" class="settings-section settings-form">
                                @Html.AntiForgeryToken()
                                <div class="settings-section-head">
                                    <div>
                                        <div class="management-kicker">Trading Infrastructure</div>
                                        <h5 class="mb-1 fw-bold">Market Data Providers</h5>
                                        <p class="text-muted mb-0">Configure the primary price provider for the Trading module directly from the admin UI.</p>
                                    </div>
                                </div>

                                @if (Model.MarketDataTestResult != null)
                                {
                                    <div class="settings-card-block">
                                        <div class="d-flex align-items-start gap-2">
                                            <i class="bi @(Model.MarketDataTestResult.Success ? "bi-check-circle-fill text-success" : "bi-exclamation-triangle-fill text-danger") mt-1"></i>
                                            <div>
                                                <div class="fw-bold small">@Model.MarketDataTestResult.Message</div>
                                                <div class="small text-muted">Provider: <strong>@Model.MarketDataTestResult.ProviderName</strong> - Status: <strong>@Model.MarketDataTestResult.Status</strong></div>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <div class="settings-card-block">
                                    <div class="alert alert-warning mb-0">
                                        This page controls advisory market data only. Broker logins and trade execution are not supported.
                                    </div>
                                </div>

                                <div class="d-flex flex-column gap-3">
                                    @for (var i = 0; i < Model.MarketData.Providers.Count; i++)
                                    {
                                        var provider = Model.MarketData.Providers[i];
                                        <div class="settings-card-block">
                                            <input asp-for="MarketData.Providers[i].Id" type="hidden" />
                                            <input asp-for="MarketData.Providers[i].ProviderName" type="hidden" />
                                            <input asp-for="MarketData.Providers[i].ProviderLabel" type="hidden" />
                                            <input asp-for="MarketData.Providers[i].HasApiKey" type="hidden" />
                                            <input asp-for="MarketData.Providers[i].MaskedApiKey" type="hidden" />
                                            <input asp-for="MarketData.Providers[i].SupportsApiKey" type="hidden" />
                                            <input asp-for="MarketData.Providers[i].IsExperimental" type="hidden" />
                                            <input asp-for="MarketData.Providers[i].LastTestResult" type="hidden" />
                                            <input asp-for="MarketData.Providers[i].LastTestDate" type="hidden" />

                                            <div class="row g-3 align-items-start">
                                                <div class="col-lg-3">
                                                    <div class="fw-bold">@provider.ProviderLabel</div>
                                                    <div class="small text-muted">Status: @provider.Status</div>
                                                    <div class="small text-muted">Last Test: @(provider.LastTestDate?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "Never")</div>
                                                </div>
                                                <div class="col-lg-3">
                                                    <div class="form-check form-switch mb-2">
                                                        <input asp-for="MarketData.Providers[i].IsEnabled" class="form-check-input" type="checkbox" />
                                                        <label asp-for="MarketData.Providers[i].IsEnabled" class="form-check-label fw-bold small">Enabled</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="MarketData.Providers.PrimarySelection" value="@provider.ProviderName" @(provider.IsPrimary ? "checked" : null) data-primary-radio />
                                                        <input asp-for="MarketData.Providers[i].IsPrimary" type="hidden" value="@provider.IsPrimary.ToString().ToLowerInvariant()" />
                                                        <label class="form-check-label fw-bold small">Primary provider</label>
                                                    </div>
                                                </div>
                                                <div class="col-lg-4">
                                                    @if (provider.SupportsApiKey)
                                                    {
                                                        <label asp-for="MarketData.Providers[i].ApiKey" class="form-label fw-bold small">API Key</label>
                                                        <input asp-for="MarketData.Providers[i].ApiKey" class="form-control" type="password" autocomplete="new-password" placeholder="Leave blank to keep existing" />
                                                        <div class="form-text">Current: @provider.MaskedApiKey</div>
                                                        <div class="form-check mt-2">
                                                            <input asp-for="MarketData.Providers[i].ClearApiKey" class="form-check-input" type="checkbox" />
                                                            <label asp-for="MarketData.Providers[i].ClearApiKey" class="form-check-label small">Clear saved key</label>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="small text-muted pt-4">This provider does not require an API key.</div>
                                                    }
                                                    @if (provider.IsExperimental)
                                                    {
                                                        <div class="alert alert-warning py-2 px-3 mt-3 mb-0 small">Experimental provider. Response format may change without notice.</div>
                                                    }
                                                </div>
                                                <div class="col-lg-2">
                                                    <label asp-for="MarketData.Providers[i].Notes" class="form-label fw-bold small">Notes</label>
                                                    <textarea asp-for="MarketData.Providers[i].Notes" class="form-control" rows="3"></textarea>
                                                </div>
                                            </div>

                                            <div class="d-flex justify-content-between align-items-center gap-2 mt-3 flex-wrap">
                                                <div class="small text-muted">Last result: <strong>@(string.IsNullOrWhiteSpace(provider.LastTestResult) ? "Not tested" : provider.LastTestResult)</strong></div>
                                                <button type="submit" class="btn btn-outline-primary btn-sm" formaction="@Url.Action("TestMarketData", "Settings", new { providerName = provider.ProviderName })">
                                                    <i class="bi bi-plug"></i> Test Connection
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="settings-form-actions">
                                    <button type="submit" class="btn btn-primary px-4" formaction="@Url.Action("SaveMarketData", "Settings")">
                                        <i class="bi bi-save"></i> Save Market Data
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<form asp-action="GenerateMcpApiKey" method="post" id="generateMcpApiKeyForm" class="d-none">
    @Html.AntiForgeryToken()
</form>

@foreach (var key in Model.Mcp.Keys.Where(item => item.IsActive))
{
    <form asp-action="RevokeMcpApiKey" method="post" id="revokeMcpApiKeyForm-@key.Id" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@key.Id" />
    </form>
}

@section Scripts {
    <script>
        document.querySelectorAll('#settings-tabs [data-bs-toggle="pill"]').forEach(tab => {
            tab.addEventListener('shown.bs.tab', function (event) {
                const target = event.target.getAttribute('data-bs-target');
                const url = new URL(window.location.href);
                url.searchParams.set('tab', target === '#settings-ai'
                    ? 'ai'
                    : target === '#settings-integration'
                        ? 'integration'
                        : target === '#settings-database'
                            ? 'database'
                            : target === '#settings-market-data'
                                ? 'market-data'
                            : 'display');
                history.replaceState({}, '', url);
            });
        });

        (function () {
            const form = document.getElementById('marketDataSettingsForm');
            if (!form) {
                return;
            }

            const radios = form.querySelectorAll('[data-primary-radio]');
            function syncPrimaryFlags() {
                radios.forEach(radio => {
                    const card = radio.closest('.settings-card-block');
                    const hidden = card?.querySelector('input[name$=".IsPrimary"][type="hidden"]');
                    if (hidden) {
                        hidden.value = radio.checked ? 'true' : 'false';
                    }
                });
            }

            radios.forEach(radio => radio.addEventListener('change', syncPrimaryFlags));
            syncPrimaryFlags();
        })();

        (function () {
            const zeroSettingsPanel = document.querySelector('[data-zero-settings-panel]');
            const aiSubtabs = document.querySelectorAll('.settings-subtabs-nav [data-bs-toggle="pill"]');

            function syncZeroSettingsPanel() {
                if (!zeroSettingsPanel) {
                    return;
                }

                const activeSubtab = document.querySelector('.settings-subtabs-nav .btn.active');
                const target = activeSubtab?.getAttribute('data-bs-target');
                zeroSettingsPanel.hidden = target !== '#ai-config-panel';
            }

            aiSubtabs.forEach(tab => {
                tab.addEventListener('shown.bs.tab', syncZeroSettingsPanel);
            });
            syncZeroSettingsPanel();
        })();

        (function () {
            const provider = document.querySelector('[data-ai-provider]');
            const endpoint = document.querySelector('[data-ai-endpoint]');
            const apiKey = document.querySelector('[data-ai-api-key]');
            const model = document.querySelector('[data-ai-model]');
            const loadButton = document.querySelector('[data-ai-load-models]');
            const testButton = document.querySelector('[data-ai-test]');
            const testMessage = document.querySelector('[data-ai-test-message]');
            const testBadge = document.querySelector('[data-ai-test-badge]');

            if (!provider || !endpoint || !model || !loadButton || !testButton) {
                return;
            }

            function setHealthState(isHealthy, message) {
                if (testMessage) {
                    testMessage.textContent = message || '';
                }

                if (testBadge) {
                    testBadge.textContent = isHealthy ? 'Online' : 'Offline';
                    testBadge.classList.toggle('bg-success-subtle', isHealthy);
                    testBadge.classList.toggle('text-success', isHealthy);
                    testBadge.classList.toggle('bg-light', !isHealthy);
                    testBadge.classList.toggle('text-muted', !isHealthy);
                }
            }

            async function loadModels(preserveCurrent) {
                const currentValue = preserveCurrent ? (model.value || model.dataset.currentValue || '') : '';
                const url = new URL('@Url.Action("AiModels", "Settings")', window.location.origin);
                url.searchParams.set('providerType', provider.value);
                url.searchParams.set('endpointUrl', endpoint.value);
                if (currentValue) {
                    url.searchParams.set('modelId', currentValue);
                }
                if (apiKey && apiKey.value && apiKey.value !== 'configured') {
                    url.searchParams.set('apiKey', apiKey.value);
                }

                loadButton.disabled = true;
                loadButton.textContent = 'Loading...';

                try {
                    const response = await fetch(url);
                    const payload = await response.json();
                    const models = Array.isArray(payload.models) ? payload.models : [];
                    model.innerHTML = '';

                    if (models.length === 0) {
                        const option = document.createElement('option');
                        option.value = currentValue;
                        option.textContent = currentValue || 'No models found';
                        model.appendChild(option);
                        setHealthState(false, payload.error || 'No models returned from endpoint.');
                        return;
                    }

                    models.forEach(item => {
                        const option = document.createElement('option');
                        option.value = item;
                        option.textContent = item;
                        option.selected = item === currentValue;
                        model.appendChild(option);
                    });

                    if (!model.value && models[0]) {
                        model.value = models[0];
                    }

                    model.dataset.currentValue = model.value;
                    setHealthState(true, 'Model list loaded from endpoint.');
                } catch {
                    setHealthState(false, 'Failed to load models from the configured endpoint.');
                } finally {
                    loadButton.disabled = false;
                    loadButton.textContent = 'Load Models';
                }
            }

            async function testAi() {
                const url = new URL('@Url.Action("TestAi", "Settings")', window.location.origin);
                url.searchParams.set('providerType', provider.value);
                url.searchParams.set('endpointUrl', endpoint.value);
                url.searchParams.set('modelId', model.value);
                if (apiKey && apiKey.value && apiKey.value !== 'configured') {
                    url.searchParams.set('apiKey', apiKey.value);
                }

                testButton.disabled = true;
                testButton.innerHTML = '<i class="bi bi-hourglass-split"></i> Testing...';

                try {
                    const response = await fetch(url);
                    const payload = await response.json();
                    setHealthState(Boolean(payload.healthy), payload.message || 'No response from provider.');
                } catch {
                    setHealthState(false, 'Failed to test the configured provider.');
                } finally {
                    testButton.disabled = false;
                    testButton.innerHTML = '<i class="bi bi-plug"></i> Test AI';
                }
            }

            provider.addEventListener('change', () => loadModels(false));
            endpoint.addEventListener('change', () => loadModels(true));
            model.addEventListener('change', () => {
                model.dataset.currentValue = model.value;
            });
            loadButton.addEventListener('click', () => loadModels(true));
            testButton.addEventListener('click', testAi);

            if (provider.value === '@((int)ScheduleApp.Models.AiProviderType.Ollama)' && endpoint.value) {
                loadModels(true);
            }
        })();
    </script>
}
