@model ScheduleApp.Models.ViewModels.SettingsPageViewModel
@{
    ViewData["Title"] = "Settings";
    bool isAiTab = string.Equals(Model.ActiveTab, "ai", StringComparison.OrdinalIgnoreCase);
    bool isIntegrationTab = string.Equals(Model.ActiveTab, "integration", StringComparison.OrdinalIgnoreCase);
    bool isDatabaseTab = false;
    bool isMarketDataTab = false;
    bool isDisplayTab = !isAiTab && !isIntegrationTab;

    var timeOptions = new List<string>();
    for (int h = 0; h < 24; h++)
    {
        timeOptions.Add($"{h:D2}:00");
        timeOptions.Add($"{h:D2}:30");
    }
}

<div class="settings-shell d-flex flex-column">
    <div class="settings-header d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <div class="management-kicker">System Preferences</div>
            <h4 class="mb-1 fw-bold">Settings Workspace</h4>
            <p class="text-muted mb-0">Local agent preferences, memory, calendar, email, and display settings live together here.</p>
        </div>
    </div>

    @if (Model.Saved)
    {
        <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-2 mb-3 settings-alert" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <div class="small fw-bold">Preferences saved successfully.</div>
        </div>
    }

    @if (Model.AiSaved)
    {
        <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-2 mb-3 settings-alert" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <div class="small fw-bold">AI settings saved successfully.</div>
        </div>
    }

    @if (Model.IntegrationSaved)
    {
        <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-2 mb-3 settings-alert" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <div class="small fw-bold">Google integration settings updated successfully.</div>
        </div>
    }

    @if (Model.McpSaved)
    {
        <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-2 mb-3 settings-alert" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <div class="small fw-bold">MCP access settings updated successfully.</div>
        </div>
    }

    @if (Model.ZeroSaved)
    {
        <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-2 mb-3 settings-alert" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <div class="small fw-bold">Zero Assistant settings saved successfully.</div>
        </div>
    }

    @if (Model.DatabaseSaved)
    {
        <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-2 mb-3 settings-alert" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <div class="small fw-bold">Database settings saved successfully.</div>
        </div>
    }

    @if (Model.MarketDataSaved)
    {
        <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-2 mb-3 settings-alert" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <div class="small fw-bold">Market data settings saved successfully.</div>
        </div>
    }

    @if (TempData["IntegrationError"] is string integrationError && !string.IsNullOrWhiteSpace(integrationError))
    {
        <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center gap-2 mb-3 settings-alert" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div class="small fw-bold">@integrationError</div>
        </div>
    }

    <div class="settings-workspace">
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="row g-0">
                <div class="col-xl-3 col-lg-4 settings-nav-panel">
                    <div class="settings-nav-shell h-100">
                        <div class="settings-nav-head">
                            <div class="settings-nav-icon">
                                <i class="bi bi-sliders"></i>
                            </div>
                            <div>
                                <div class="management-kicker">Sections</div>
                                <h6 class="mb-0 fw-bold">Preference Areas</h6>
                            </div>
                        </div>

                        <div class="nav flex-column nav-pills settings-nav-tabs" id="settings-tabs" role="tablist" aria-orientation="vertical">
                            <button class="nav-link @(isDisplayTab ? "active" : string.Empty)" id="settings-display-tab" data-bs-toggle="pill" data-bs-target="#settings-display" type="button" role="tab" aria-controls="settings-display" aria-selected="@isDisplayTab.ToString().ToLowerInvariant()">
                                <span class="settings-tab-icon"><i class="bi bi-calendar3"></i></span>
                                <span>
                                    <strong>Calendar & Display</strong>
                                    <small>Timeline visibility and focus</small>
                                </span>
                            </button>
                            <button class="nav-link @(isAiTab ? "active" : string.Empty)" id="settings-ai-tab" data-bs-toggle="pill" data-bs-target="#settings-ai" type="button" role="tab" aria-controls="settings-ai" aria-selected="@isAiTab.ToString().ToLowerInvariant()">
                                <span class="settings-tab-icon"><i class="bi bi-stars"></i></span>
                                <span>
                                    <strong>AI Assistant</strong>
                                    <small>Provider, guardrails, monitoring</small>
                                </span>
                            </button>
                            <button class="nav-link @(isIntegrationTab ? "active" : string.Empty)" id="settings-integration-tab" data-bs-toggle="pill" data-bs-target="#settings-integration" type="button" role="tab" aria-controls="settings-integration" aria-selected="@isIntegrationTab.ToString().ToLowerInvariant()">
                                <span class="settings-tab-icon"><i class="bi bi-google"></i></span>
                                <span>
                                    <strong>Email & Calendar</strong>
                                    <small>Google account, inbox, calendar sync</small>
                                </span>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-xl-9 col-lg-8">
                    <div class="tab-content settings-content" id="settings-tab-content">
                        <div class="tab-pane fade settings-tab-pane @(isDisplayTab ? "show active" : string.Empty)" id="settings-display" role="tabpanel" aria-labelledby="settings-display-tab" tabindex="0">
                            <form asp-action="SavePreferences" method="post" id="preferencesForm" class="settings-section settings-form">
                                @Html.AntiForgeryToken()
                                <div class="settings-section-head">
                                    <div>
                                        <div class="management-kicker">Schedule Display</div>
                                        <h5 class="mb-1 fw-bold">Calendar Preferences</h5>
                                        <p class="text-muted mb-0">Define the day range emphasized across the calendar and schedule surfaces.</p>
                                    </div>
                                </div>

                                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <div class="settings-card-block">
                                            <label class="form-label fw-bold small mb-2">Day Start Time</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-sunrise"></i></span>
                                                <select asp-for="Preferences.DayStartTime" class="form-select border-start-0 ps-0">
                                                    @foreach (var time in timeOptions)
                                                    {
                                                        <option value="@time">@time</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="settings-card-block">
                                            <label class="form-label fw-bold small mb-2">Day End Time</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-sunset"></i></span>
                                                <select asp-for="Preferences.DayEndTime" class="form-select border-start-0 ps-0">
                                                    @foreach (var time in timeOptions)
                                                    {
                                                        <option value="@time">@time</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="settings-card-block mt-4">
                                    <div class="form-check form-switch settings-switch-row">
                                        <div>
                                            <label class="form-check-label fw-bold small d-block" asp-for="Preferences.ShowFullDayInCalendar">Show Full 24 Hours</label>
                                            <span class="text-muted small">Show all hours instead of using the focused day range.</span>
                                        </div>
                                        <input class="form-check-input ms-0" type="checkbox" asp-for="Preferences.ShowFullDayInCalendar">
                                    </div>
                                </div>

                                <div class="settings-card-block mt-4">
                                    <label class="form-label fw-bold small mb-2">Header World Clocks</label>
                                    <div class="text-muted small mb-3">Select up to 4 cities to display real-time clocks on the top header bar.</div>
                                    <div class="row g-3">
                                        @{
                                            var timezones = new Dictionary<string, string> {
                                                {"", "- None -"},
                                                {"Pacific/Auckland", "Auckland"},
                                                {"Australia/Sydney", "Sydney"},
                                                {"Asia/Tokyo", "Tokyo"},
                                                {"Asia/Singapore", "Singapore"},
                                                {"Asia/Yangon", "Yangon"},
                                                {"Asia/Dubai", "Dubai"},
                                                {"Europe/Paris", "Paris"},
                                                {"Europe/Berlin", "Berlin"},
                                                {"Europe/London", "London"},
                                                {"America/New_York", "New York"},
                                                {"America/Chicago", "Chicago"},
                                                {"America/Denver", "Denver"},
                                                {"America/Los_Angeles", "Los Angeles"}
                                            };
                                            var tzSelectList = new SelectList(timezones, "Key", "Value");
                                        }
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold small text-muted">Clock 1</label>
                                            <select asp-for="Preferences.Clock1TimeZone" asp-items="tzSelectList" class="form-select"></select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold small text-muted">Clock 2</label>
                                            <select asp-for="Preferences.Clock2TimeZone" asp-items="tzSelectList" class="form-select"></select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold small text-muted">Clock 3</label>
                                            <select asp-for="Preferences.Clock3TimeZone" asp-items="tzSelectList" class="form-select"></select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold small text-muted">Clock 4</label>
                                            <select asp-for="Preferences.Clock4TimeZone" asp-items="tzSelectList" class="form-select"></select>
                                        </div>
                                    </div>
                                </div>


                                <div class="settings-form-actions">
                                    <button type="submit" class="btn btn-primary px-4">
                                        <i class="bi bi-check-lg"></i> Save Preferences
                                    </button>
                                </div>
                            </form>
                        </div>

                        <div class="tab-pane fade settings-tab-pane @(isAiTab ? "show active" : string.Empty)" id="settings-ai" role="tabpanel" aria-labelledby="settings-ai-tab" tabindex="0">
                            <form asp-action="SaveAi" method="post" id="aiSettingsForm" class="settings-section settings-form">
                                @Html.AntiForgeryToken()
                                <div class="settings-section-head">
                                    <div>
                                        <div class="management-kicker">Agent Orchestration</div>
                                        <h5 class="mb-1 fw-bold">AI Assistant Settings</h5>
                                        <p class="text-muted mb-0">Configure the provider, tool-calling, scheduling guardrails, and monitoring policy.</p>
                                    </div>
                                </div>

                                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                                <div class="settings-subtabs">
                                    <div class="segmented-control settings-subtabs-nav mb-3" role="tablist" aria-label="AI settings sections">
                                        <button type="button" class="btn active" id="ai-config-tab" data-bs-toggle="pill" data-bs-target="#ai-config-panel" role="tab" aria-controls="ai-config-panel" aria-selected="true">
                                            Configuration
                                        </button>
                                        <button type="button" class="btn" id="ai-proactive-tab" data-bs-toggle="pill" data-bs-target="#ai-proactive-panel" role="tab" aria-controls="ai-proactive-panel" aria-selected="false">
                                            Proactive Assist
                                        </button>
                                        <button type="button" class="btn" id="ai-tools-tab" data-bs-toggle="pill" data-bs-target="#ai-tools-panel" role="tab" aria-controls="ai-tools-panel" aria-selected="false">
                                            Available Tools
                                        </button>
                                    </div>

                                    <div class="tab-content">
                                        <div class="tab-pane fade show active" id="ai-config-panel" role="tabpanel" aria-labelledby="ai-config-tab" tabindex="0">
                                            <div class="settings-card-block">
                                                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                                                    <div>
                                                        <div class="fw-bold">Provider Health</div>
                                                        <div class="small text-muted" data-ai-test-message>@Model.AiHealthMessage</div>
                                                    </div>
                                                    <span class="badge @(string.Equals(Model.AiHealthStatus, "Online", StringComparison.OrdinalIgnoreCase) ? "bg-success-subtle text-success" : "bg-light text-muted") px-3 py-2 rounded-pill" data-ai-test-badge>@(Model.AiHealthStatus ?? "Offline")</span>
                                                </div>
                                            </div>

                                            <div class="settings-card-block">
                                                <div class="row g-4">
                                                    <div class="col-md-4">
                                                        <label asp-for="Ai.ProviderType" class="form-label fw-bold small">Provider</label>
                                                        <select asp-for="Ai.ProviderType" asp-items="Html.GetEnumSelectList<ScheduleApp.Models.AiProviderType>()" class="form-select" data-ai-provider></select>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label asp-for="Ai.ModelId" class="form-label fw-bold small">Model Id</label>
                                                        <select asp-for="Ai.ModelId" class="form-select" data-ai-model data-current-value="@Model.Ai.ModelId">
                                                            <option value="@Model.Ai.ModelId">@Model.Ai.ModelId</option>
                                                        </select>
                                                        <span asp-validation-for="Ai.ModelId" class="text-danger small"></span>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label asp-for="Ai.EndpointUrl" class="form-label fw-bold small">Endpoint</label>
                                                        <div class="input-group">
                                                            <input asp-for="Ai.EndpointUrl" class="form-control" data-ai-endpoint />
                                                            <button type="button" class="btn btn-outline-primary" data-ai-load-models>Load Models</button>
                                                        </div>
                                                        <span asp-validation-for="Ai.EndpointUrl" class="text-danger small"></span>
                                                    </div>
                                                    <div class="col-md-8">
                                                        <label asp-for="Ai.ApiKey" class="form-label fw-bold small">API Key</label>
                                                        <input asp-for="Ai.ApiKey" class="form-control" placeholder="Leave blank to keep existing secret" data-ai-api-key />
                                                        <div class="form-text">Ollama can leave this empty. Hosted providers should use a secret value here.</div>
                                                    </div>
                                                    <div class="col-md-4 d-flex align-items-end">
                                                        <div class="d-flex align-items-center gap-3 flex-wrap w-100 justify-content-between">
                                                            <div class="form-check form-switch">
                                                                <input asp-for="Ai.ClearApiKey" class="form-check-input" type="checkbox" />
                                                                <label asp-for="Ai.ClearApiKey" class="form-check-label small fw-bold">Clear saved key</label>
                                                            </div>
                                                            <button type="button" class="btn btn-outline-primary" data-ai-test>
                                                                <i class="bi bi-plug"></i> Test AI
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="settings-card-block mt-4">
                                                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
                                                    <div>
                                                        <div class="fw-bold">MCP Access</div>
                                                        <div class="small text-muted">External agents can connect to the authenticated MCP endpoint by sending an API key in <code>@Model.Mcp.HeaderName</code>.</div>
                                                    </div>
                                                    <span class="badge bg-light text-muted px-3 py-2 rounded-pill">@Model.Mcp.EndpointPath</span>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(Model.Mcp.NewlyGeneratedApiKey))
                                                {
                                                    <div class="alert alert-warning border-0 shadow-sm small">
                                                        <div class="fw-bold mb-1">Copy this MCP API key now.</div>
                                                        <div class="mb-2">It will not be shown again after you leave this page.</div>
                                                        <code class="d-block text-break">@Model.Mcp.NewlyGeneratedApiKey</code>
                                                    </div>
                                                }

                                                <div class="row g-3 align-items-end">
                                                    <div class="col-md-8">
                                                        <label asp-for="McpGenerate.Name" class="form-label fw-bold small">Key Name</label>
                                                        <input asp-for="McpGenerate.Name" class="form-control" placeholder="External Agent" form="generateMcpApiKeyForm" />
                                                        <span asp-validation-for="McpGenerate.Name" class="text-danger small"></span>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <button type="submit" class="btn btn-primary w-100" form="generateMcpApiKeyForm">
                                                            <i class="bi bi-key"></i> Generate API Key
                                                        </button>
                                                    </div>
                                                </div>

                                                <div class="small text-muted mt-3 mb-2">
                                                    Endpoint: <code>@($"{Context.Request.Scheme}://{Context.Request.Host}{Model.Mcp.EndpointPath}")</code>
                                                </div>

                                                @if (Model.Mcp.Keys.Count == 0)
                                                {
                                                    <div class="small text-muted mt-3">No MCP API keys have been created for this account yet.</div>
                                                }
                                                else
                                                {
                                                    <div class="table-responsive mt-3">
                                                        <table class="table table-sm align-middle mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th>Name</th>
                                                                    <th>Prefix</th>
                                                                    <th>Status</th>
                                                                    <th>Last Used</th>
                                                                    <th></th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var key in Model.Mcp.Keys)
                                                                {
                                                                    <tr>
                                                                        <td class="fw-semibold">@key.Name</td>
                                                                        <td><code>@key.KeyPrefix</code></td>
                                                                        <td>
                                                                            <span class="badge @(key.IsActive ? "bg-success-subtle text-success" : "bg-light text-muted")">
                                                                                @(key.IsActive ? "Active" : "Revoked")
                                                                            </span>
                                                                        </td>
                                                                        <td class="text-muted small">@(key.LastUsedAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                                                                        <td class="text-end">
                                                                            @if (key.IsActive)
                                                                            {
                                                                                <button type="submit" class="btn btn-outline-danger btn-sm" form="revokeMcpApiKeyForm-@key.Id">Revoke</button>
                                                                            }
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                            </div>

                                            <div class="settings-card-block">
                                                <div class="row g-4">
                                                    <div class="col-md-3">
                                                        <label asp-for="Ai.Temperature" class="form-label fw-bold small">Temperature</label>
                                                        <input asp-for="Ai.Temperature" class="form-control" type="number" step="0.1" min="0" max="2" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label asp-for="Ai.MaxTokens" class="form-label fw-bold small">Max Tokens</label>
                                                        <input asp-for="Ai.MaxTokens" class="form-control" type="number" min="1" max="16000" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        @{
                                                            var aiTimezones = new Dictionary<string, string> {
                                                                {"Pacific/Auckland", "Auckland"},
                                                                {"Australia/Sydney", "Sydney"},
                                                                {"Asia/Tokyo", "Tokyo"},
                                                                {"Asia/Singapore", "Singapore"},
                                                                {"Asia/Yangon", "Yangon"},
                                                                {"Asia/Dubai", "Dubai"},
                                                                {"Europe/Paris", "Paris"},
                                                                {"Europe/Berlin", "Berlin"},
                                                                {"Europe/London", "London"},
                                                                {"America/New_York", "New York"},
                                                                {"America/Chicago", "Chicago"},
                                                                {"America/Denver", "Denver"},
                                                                {"America/Los_Angeles", "Los Angeles"}
                                                            };
                                                            var aiTzSelectList = new SelectList(aiTimezones, "Key", "Value");
                                                        }
                                                        <label asp-for="Ai.DefaultTimeZone" class="form-label fw-bold small">Local Time Zone</label>
                                                        <select asp-for="Ai.DefaultTimeZone" asp-items="aiTzSelectList" class="form-select"></select>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label asp-for="Ai.WorkingDays" class="form-label fw-bold small">Working Days</label>
                                                        <input asp-for="Ai.WorkingDays" class="form-control" placeholder="Mon,Tue,Wed,Thu,Fri" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label asp-for="Ai.WorkingHoursStart" class="form-label fw-bold small">Working Start</label>
                                                        <input asp-for="Ai.WorkingHoursStart" class="form-control" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label asp-for="Ai.WorkingHoursEnd" class="form-label fw-bold small">Working End</label>
                                                        <input asp-for="Ai.WorkingHoursEnd" class="form-control" />
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="settings-card-block">
                                                <label asp-for="Ai.SystemPrompt" class="form-label fw-bold small">System Prompt</label>
                                                <textarea asp-for="Ai.SystemPrompt" rows="8" class="form-control"></textarea>
                                                <span asp-validation-for="Ai.SystemPrompt" class="text-danger small"></span>
                                            </div>

                                            <div class="settings-card-block">
                                                <div class="row g-3">
                                                    <div class="col-md-6">
                                                        <div class="form-check form-switch">
                                                            <input asp-for="Ai.IsEnabled" class="form-check-input" type="checkbox" />
                                                            <label asp-for="Ai.IsEnabled" class="form-check-label fw-bold small">Enable AI assistant</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-check form-switch">
                                                            <input asp-for="Ai.EnableToolCalling" class="form-check-input" type="checkbox" />
                                                            <label asp-for="Ai.EnableToolCalling" class="form-check-label fw-bold small">Enable tool calling</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-check form-switch">
                                                            <input asp-for="Ai.EnableStreaming" class="form-check-input" type="checkbox" />
                                                            <label asp-for="Ai.EnableStreaming" class="form-check-label fw-bold small">Enable streaming</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-check form-switch">
                                                            <input asp-for="Ai.EnableProgressMonitoring" class="form-check-input" type="checkbox" />
                                                            <label asp-for="Ai.EnableProgressMonitoring" class="form-check-label fw-bold small">Enable progress monitoring</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-check form-switch">
                                                            <input asp-for="Ai.AutoCreateLowRiskTasks" class="form-check-input" type="checkbox" />
                                                            <label asp-for="Ai.AutoCreateLowRiskTasks" class="form-check-label fw-bold small">Auto-create low-risk follow-ups</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-check form-switch">
                                                            <input asp-for="Ai.RequireApprovalForScheduleChange" class="form-check-input" type="checkbox" />
                                                            <label asp-for="Ai.RequireApprovalForScheduleChange" class="form-check-label fw-bold small">Require approval for schedule changes</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-check form-switch">
                                                            <input asp-for="Ai.RequireApprovalForTaskDeletion" class="form-check-input" type="checkbox" />
                                                            <label asp-for="Ai.RequireApprovalForTaskDeletion" class="form-check-label fw-bold small">Require approval for task deletion</label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

