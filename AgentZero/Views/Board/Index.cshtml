@using ScheduleApp.Models
@model List<ScheduleEvent>
@{
    ViewData["Title"] = "Product Board";
    var selectedProject = (Project?)ViewBag.SelectedProject;
    var projects = (List<Project>)(ViewBag.Projects ?? new List<Project>());
    var stages = (List<ProjectStage>)(ViewBag.Stages ?? new List<ProjectStage>());
    var selectedStageId = (int?)ViewBag.SelectedStageId;
    
    // Automation Stats
    var overdueCount = Model.Count(e => e.IsOverdue);
    var doneTasks = Model.Count(e => e.Status == EventStatus.Done);
    var blockedCount = Model.Count(e => e.Status == EventStatus.Blocked);
}

<div class="h-100 d-flex flex-column" style="overflow: hidden;">
    <!-- Board Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <h5 class="mb-0 fw-bold">@(selectedProject?.Name ?? "General Roadmap")</h5>
            <div class="dropdown">
                <button class="btn btn-soft dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    Filter by Product
                </button>
                <ul class="dropdown-menu shadow-sm border-0">
                    <li><a class="dropdown-item" asp-action="Index">View All</a></li>
                    <li><hr class="dropdown-divider"></li>
                    @foreach (var p in projects)
                    {
                        <li><a class="dropdown-item" asp-action="Index" asp-route-projectId="@p.Id">@p.Name</a></li>
                    }
                </ul>
            </div>
            @if (selectedProject != null)
            {
                <div class="dropdown">
                    <button class="btn btn-soft dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        @(selectedStageId.HasValue
                            ? stages.FirstOrDefault(stage => stage.Id == selectedStageId)?.Name ?? "Stage"
                            : "All Stages")
                    </button>
                    <ul class="dropdown-menu shadow-sm border-0">
                        <li><a class="dropdown-item" asp-action="Index" asp-route-projectId="@selectedProject.Id">All Stages</a></li>
                        @if (stages.Any())
                        {
                            <li><hr class="dropdown-divider"></li>
                            @foreach (var stage in stages)
                            {
                                <li>
                                    <a class="dropdown-item" asp-action="Index" asp-route-projectId="@selectedProject.Id" asp-route-stageId="@stage.Id">
                                        @stage.Name
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            }
        </div>
        
        <div class="view-switch segmented-control">
            <button class="btn active" onclick="switchTab('kanban')" id="tab-kanban" type="button">Kanban</button>
            <button class="btn" onclick="switchTab('gantt')" id="tab-gantt" type="button">Timeline</button>
            <button class="btn" onclick="switchTab('gallery')" id="tab-gallery" type="button">Box View</button>
        </div>
    </div>

    <!-- Layout Grid -->
    <div class="row flex-grow-1 overflow-hidden g-3">
        <!-- Main Board Area -->
        <div class="col-lg-10 h-100 overflow-hidden d-flex flex-column">
            <!-- Kanban View -->
            <div id="view-kanban" class="view-pane h-100">
                <div class="kanban-scroller h-100 d-flex gap-3 overflow-auto pb-4">
                    @foreach (var status in Enum.GetValues<EventStatus>().Where(status => status != EventStatus.Blocked))
                    {
                        var statusEvents = Model.Where(e => e.Status == status).ToList();
                        var isEmpty = statusEvents.Count == 0;
                        <div class="kanban-col @(isEmpty ? "empty-col" : "")">
                            <div class="kanban-header">
                                <span class="status-dot @status"></span>
                                <span class="status-name">@status</span>
                                <span class="status-count">@statusEvents.Count</span>
                            </div>
                            <div class="kanban-body sortable-list" data-status="@status">
                                @foreach (var evt in statusEvents)
                                {
                                    <div class="kanban-item" data-id="@evt.Id">
                                        <partial name="../Events/_EventCard" model="evt" />
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div id="view-gantt" class="view-pane d-none h-100 position-relative gantt-pane">
                <div class="gantt-zoom-panel segmented-control">
                    <div class="d-flex align-items-center gap-1">
                        <button class="btn active" id="zoom-Day" onclick="changeGanttZoom('Day')" type="button">Day</button>
                        <button class="btn" id="zoom-Week" onclick="changeGanttZoom('Week')" type="button">Week</button>
                        <button class="btn" id="zoom-Month" onclick="changeGanttZoom('Month')" type="button">Month</button>
                        <button class="btn" id="zoom-Year" onclick="changeGanttZoom('Year')" type="button">Year</button>
                    </div>
                </div>
                <div class="card h-100 border-0 shadow-sm overflow-hidden gantt-card">
                    <div id="gantt-container" class="h-100 position-relative bg-white"></div>
                </div>
            </div>

            <!-- Gallery View -->
            <div id="view-gallery" class="view-pane d-none h-100 overflow-auto">
                <div class="row g-2">
                    @foreach (var evt in Model)
                    {
                        <div class="col-sm-6 col-md-4 col-xl-3">
                            <partial name="../Events/_EventCard" model="evt" />
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Automation Sidebar -->
        <div class="col-lg-2">
            <div class="card border-0 shadow-sm mb-3 sidebar-card">
                <div class="card-body p-3">
                    <h6 class="section-title">Health Checks</h6>
                    
                    <div class="stat-row">
                        <span class="label">Overdue</span>
                        <span class="value @(overdueCount > 0 ? "urgent" : "")">@overdueCount</span>
                    </div>
                    <div class="stat-row">
                        <span class="label">Blocked</span>
                        <span class="value @(blockedCount > 0 ? "warning" : "")">@blockedCount</span>
                    </div>
                    
                    <hr class="my-3 opacity-10">
                    
                    <div class="progress-container">
                        @{
                            var totalCount = Model.Count > 0 ? Model.Count : 1;
                            var completion = (int)((double)doneTasks / totalCount * 100);
                        }
                        <div class="d-flex justify-content-between mb-2">
                            <span class="label">Completion</span>
                            <span class="percent">@completion%</span>
                        </div>
                        <div class="progress" style="height: 6px; box-shadow: inset 0 1px 2px rgba(0,0,0,0.1);">
                            <div class="progress-bar bg-success" style="width: @completion%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert health-alert border-0 shadow-sm">
                <div class="fw-bold mb-1"><i class="bi bi-shield-check me-2"></i>Smart Sync</div>
                Tasks unblock when precursors are <b>Done</b>.
            </div>
        </div>
    </div>
</div>

<!-- Gantt Data -->
<template id="gantt-tasks">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrderBy(e => e.Stage?.Name ?? e.AreaName).Select(e => new {
        id = e.Id.ToString(),
        name = $"{(string.IsNullOrEmpty(e.Stage?.Name ?? e.AreaName) ? "" : $"[{(e.Stage?.Name ?? e.AreaName)}] ")}{e.Title}",
        start = e.StartDateTime.ToString("s"),
        end = (e.EndDateTime <= e.StartDateTime ? e.StartDateTime.AddHours(1) : e.EndDateTime).ToString("s"),
        progress = e.Progress,
        dependencies = e.DependsOnId.HasValue ? e.DependsOnId.Value.ToString() : string.Empty,
        custom_class = e.CategoryId.HasValue ? $"cat-gantt-{e.CategoryId}" : "cat-gantt-default"
    })))
</template>

@section Scripts {
    <script src="~/lib/sortablejs/Sortable.min.js" asp-append-version="true"></script>
    <script src="~/lib/frappe-gantt/frappe-gantt.umd.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/lib/frappe-gantt/frappe-gantt.css" asp-append-version="true" />

    <script>
        function switchTab(view) {
            $('.view-pane').addClass('d-none');
            $('#view-' + view).removeClass('d-none');
            $('.view-switch .btn').removeClass('active');
            $('#tab-' + view).addClass('active');

            if (view === 'gantt') {
                setTimeout(initGantt, 50);
            }
        }

        document.querySelectorAll('.sortable-list').forEach(el => {
            new Sortable(el, {
                group: 'kanban',
                animation: 150,
                onEnd: function (evt) {
                    const eventId = evt.item.dataset.id;
                    const newStatus = evt.to.dataset.status;
                    $.post('/Board/UpdateEventStatus', { eventId, status: newStatus });
                }
            });
        });

        function initGantt() {
            const data = JSON.parse(document.getElementById('gantt-tasks').innerHTML);
            if (!data.length) return;
            if (!window.chart) {
                window.chart = new Gantt("#gantt-container", data, {
                    on_click: t => window.location.href = '/Events/Edit/' + t.id,
                    view_mode: 'Day',
                    holidays: {
                        'var(--g-weekend-highlight-color)': 'weekend'
                    }
                });
            }
        }

        function changeGanttZoom(mode) {
            if (window.chart) {
                window.chart.change_view_mode(mode);
                $('.gantt-zoom-panel .btn').removeClass('active');
                $(`#zoom-${mode}`).addClass('active');
            }
        }

    </script>
}

@section PageStyles {
    <style>
        @foreach (var catGroup in Model.Where(e => e.CategoryId.HasValue).GroupBy(e => e.CategoryId))
        {
            var cat = catGroup.First().Category;
            var color = cat?.Color ?? "#2E5DA6";
            <text>
            .cat-gantt-@catGroup.Key .bar { fill: @color !important; rx: 6; ry: 6; }
            .cat-gantt-@catGroup.Key .bar-label { fill: #111827 !important; font-weight: 700; font-size: 11px; }
            </text>
        }
    </style>
}
